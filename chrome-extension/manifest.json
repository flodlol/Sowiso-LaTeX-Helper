{
  "manifest_version": 3,
  "name": "Sowieso LaTeX Helper",
  "description": "Paste LaTeX, preview it, and insert it into the currently active exercise field.",
  "version": "0.1.0",
  "permissions": ["activeTab", "tabs", "storage", "sidePanel", "webNavigation", "scripting", "debugger"],
  "host_permissions": ["https://cloud.sowiso.nl/*", "https://*.sowiso.nl/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Sowieso LaTeX Helper"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://cloud.sowiso.nl/*", "https://*.sowiso.nl/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
